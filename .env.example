# ============================================
# Core App / Supabase
# ============================================
# Required (validate-env.js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required in production (validate-env.js)
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=

# Common app URL used by some auth/email flows
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================
# Optional / Operational Flags
# ============================================
ENVIRONMENT=development
MAINTENANCE_MODE=false
OPENAI_API_KEY=
BREVO_API_KEY=

# ============================================
# MFA / Auth test mode
# ============================================
# Enable only in dev/preview. Never use true in production.
SHOW_MFA_CODE=false

# Force WhatsApp mock mode even with provider credentials.
WHATSAPP_FORCE_MOCK=true

# ============================================
# Z-API (WhatsApp provider)
# ============================================
# Base URL defaults to https://api.z-api.io if omitted
Z_API_BASE_URL=https://api.z-api.io

# Required to enable real Z-API sending
Z_API_INSTANCE_ID=
Z_API_TOKEN=

# Optional, depending on your Z-API account setup
Z_API_CLIENT_TOKEN=

# Optional tuning (defaults in code)
Z_API_TIMEOUT_MS=8000
Z_API_MAX_RETRIES=2
Z_API_RETRY_BASE_DELAY_MS=400
