      "isDeleted": false,
      "boundElements": [],
      "updated": 1773430255296,
      "link": null,
      "locked": false,
      "text": "Do ponto de vista M&A, o mínimo necessário para a Mary AI gerar um teaser básico e\nenviar um convite qualificado seria:",
