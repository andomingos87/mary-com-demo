    },
    {
      "id": "kXxz9V-FfNQGBUh0DAjck",
      "type": "text",
      "x": 8114.8915597444975,
      "y": -3017.2513913375747,
      "width": 508.88104848192233,
      "height": 150,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ffffff",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bfc",
      "roundness": null,
      "seed": 1978582364,
      "version": 213,
      "versionNonce": 2104274652,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773173897425,
      "link": null,
      "locked": false,
      "text": "IMPORTANTE: Precisa criar um sistema de mensageria\nautomática da Mary, que é fundamental termos\nconcentrado em uma única tabela do BD, para termos\ngovernança sobre todos os gatilhos e mensagens que o\nsistema dispara aos usuários, para que possamos\nmanter e evoluir essa feature",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "IMPORTANTE: Precisa criar um sistema de mensageria automática da Mary, que é fundamental termos concentrado em uma única tabela do BD, para termos governança sobre todos os gatilhos e mensagens que o sistema dispara aos usuários, para que possamos manter e evoluir essa feature",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "53746QQa4LzOCM0DntFdJ",
      "type": "text",
      "x": 8098.199233103163,
      "y": -2818.684470681977,
      "width": 567.0679042001666,
      "height": 100,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ffffff",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bfd",
      "roundness": null,
      "seed": 1926430180,
      "version": 174,
      "versionNonce": 573207388,
      "isDeleted": false,
      "boundElements": [
        {
          "id": "r2IPb0YaGFYlnVBfQxYqx",
          "type": "arrow"
        }
      ],
      "updated": 1773173897425,
      "link": null,
      "locked": false,
      "text": "Tooltip: A Mary pode te ajudar com isso, enviando seu contato\npara advisors da nossa rede, que possuam match potencial\ncom seu negócio. Você não tem nenhum compromisso de\natender ou contratar nenhum deles, isso fica a seu critério.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Tooltip: A Mary pode te ajudar com isso, enviando seu contato para advisors da nossa rede, que possuam match potencial com seu negócio. Você não tem nenhum compromisso de atender ou contratar nenhum deles, isso fica a seu critério.",
      "autoResize": false,
      "lineHeight": 1.25
    },
