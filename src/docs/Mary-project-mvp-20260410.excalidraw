    {
      "id": "Wr9Kd-mv0mykKMUo9iUoD",
      "type": "text",
      "x": 6798.8889931499425,
      "y": 4016.4311007793303,
      "width": 990.8678769547112,
      "height": 439.9999999999985,
      "angle": 0,
