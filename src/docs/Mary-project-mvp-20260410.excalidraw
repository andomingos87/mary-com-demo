      "text": "STEP 3 — Quem está ao seu lado nessa jornada?",
      "fontSize": 16,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "STEP 3 — Quem está ao seu lado nessa jornada?",
      "autoResize": true,
