    {
      "id": "yBPyChbIThmpKPgkxLt0n",
      "type": "text",
      "x": 6379.007612810552,
      "y": -503.10771436211724,
      "width": 2232.110727094532,
      "height": 180,
      "angle": 0,
      "strokeColor": "#2f9e44",
      "backgroundColor": "#ffffff",
      "fillStyle": "hachure",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bh4",
      "roundness": null,
      "seed": 1341956324,
      "version": 331,
      "versionNonce": 363480028,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1773174964958,
      "link": null,
      "locked": false,
      "text": "Após finalizar o Onboarding, Mary AI deve gerar automaticamente o dossiê da empresa. Para isso, ela pega como base os campos\npreenchidos, a IA cria um documento completo usando agente “deep research” para levantar tudo que for possível sobre o ativo. Depois\ncria resumo executivo, pontos de destaque, SWOT, entre outros itens (tenho prompt pra isso pronto) e por fim, um MRS inicial. Esse\ndossiê será uma base para RAG do ativo e docs posteriormente e deverá ser alocado em Q&As.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Após finalizar o Onboarding, Mary AI deve gerar automaticamente o dossiê da empresa. Para isso, ela pega como base os campos preenchidos, a IA cria um documento completo usando agente “deep research” para levantar tudo que for possível sobre o ativo. Depois cria resumo executivo, pontos de destaque, SWOT, entre outros itens (tenho prompt pra isso pronto) e por fim, um MRS inicial. Esse dossiê será uma base para RAG do ativo e docs posteriormente e deverá ser alocado em Q&As.",
      "autoResize": false,
      "lineHeight": 1.25
    },
